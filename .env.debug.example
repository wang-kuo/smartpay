APP_MODE=debug
LOG_LEVEL=debug
AUTH_MODE=mock
MOCK_USER_ID=user_001
MOCK_EXTERNAL_SERVICES=true
REAL_PAYMENTS_ENABLED=false

SHOW_INTERNAL_TRACE=true
SHOW_RULE_EVALUATION=true
SHOW_LLM_PROMPTS=false
ALLOW_SEED_RESET=true
RATE_LIMIT_STRICT=false
PII_REDACTION=false

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DATABASE_URL=postgres://smartpay:smartpay@localhost:5432/smartpay
REDIS_URL=redis://localhost:6379

LLM_TIMEOUT_MS=15000
EXTERNAL_CALL_TIMEOUT_MS=5000
REQUEST_TIMEOUT_MS=20000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
