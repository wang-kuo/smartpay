    "@smartpay/mock-data": "workspace:*",
    "@smartpay/rules": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@vercel/node": "^5.8.4",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "tsx": "^4.22.3"
  }
}
