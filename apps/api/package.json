{
  "name": "@smartpay/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/dev.ts",
    "dev:watch": "tsx watch --clear-screen=false src/dev.ts",
